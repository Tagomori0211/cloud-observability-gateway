# .env.example — このファイルはコミットしてよい。
# 実際の .env は commit 禁止。Secret Manager から自動生成される。
#
# ---- 自動生成フロー ----
# 1. Terraform apply → Secret Manager に sushiski-tunnel-token skeleton 作成
# 2. Cloudflare Zero Trust でトンネル作成 → TUNNEL_TOKEN 取得
# 3. 手動で値を登録:
#      gcloud secrets versions add sushiski-tunnel-token --data-file=- <<< "eyJ..."
# 4. cloud-init (初回起動) または Ansible (fetch-sushiski-secrets.sh) が .env を生成
#
# ---- ローカル開発用 ----
# flutter run -d chrome では gRPC スタブが未生成のため HTTP fallback が使われる。
# バックエンドをローカルで起動する場合のみ以下を .env として使用:
TUNNEL_TOKEN=eyJ...
# mc-monitoring-1 の VPC 内部 IP (tak-subnet: 10.100.0.0/20)
# `terraform output victoria_metrics_url` または
# `gcloud compute instances describe mc-monitoring-1 --zone=asia-northeast1-b --format=get(networkInterfaces[0].networkIP)`
# で確認した値を設定。cloud-init / Ansible が自動生成するため通常は手動設定不要。
VICTORIA_METRICS_URL=http://10.100.0.X:8428
